SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE=
OAUTH_STATE_SECRET=

# Packlink (server-side)
PACKLINK_API_KEY=
PACKLINK_BASE_URL=https://api.packlink.com/v1/

# PrepBusiness (server-side)
# Base URL looks like: https://YOUR_COMPANY.prepbusiness.com/api
PREPBUSINESS_API_BASE_URL=https://your-company.prepbusiness.com/api
# API token generated from Settings → API; keep it secret and rotate if exposed
PREPBUSINESS_API_TOKEN=
# Optional webhook secret (shared secret for inbound webhook calls)
PREPBUSINESS_WEBHOOK_SECRET=
# Sync mode: manual (expect inbounds[] in request body) or api (poll PrepBusiness API)
PREPBUSINESS_SYNC_MODE=manual
# Optional custom endpoint path for inbounds when SYNC_MODE=api
PREPBUSINESS_INBOUNDS_PATH=/inbounds
